# SuperProfile Support — dashboard env template. Copy to `web/.env.local`.
# On Vercel, set this in the project's Environment Variables instead.
VITE_API_ORIGIN=http://localhost:3000     # prod: https://api.anujchhikara.com
# Public help-center (Knowledge Base) host. Falls back to VITE_API_ORIGIN if unset.
VITE_KB_ORIGIN=http://localhost:3000     # prod: https://kb.anujchhikara.com
