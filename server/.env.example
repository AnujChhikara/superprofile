# ─────────────────────────────────────────────────────────────────────────
# SuperProfile Support — server env template.
# Copy to `server/.env` and fill in real values. `.env` is gitignored.
# The server auto-loads server/.env in dev (NODE_ENV != production).
# In production, set these as Azure App Service application settings instead.
# ─────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/support
APP_ORIGIN=http://localhost:5173          # prod: https://app.anujchhikara.com
API_ORIGIN=http://localhost:3000          # prod: https://api.anujchhikara.com
KB_HOST=localhost:3000                    # prod: kb.anujchhikara.com
PARSE_DOMAIN=parse.anujchhikara.com
# COOKIE_DOMAIN=.anujchhikara.com         # prod only — leave unset locally
DEMO_MODE=true

# ── Google OAuth (REQUIRED — only login method) ───────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Optional integrations (graceful degradation if empty) ─────────────────
OPENAI_API_KEY=                           # AI summaries + drafts
SENDGRID_API_KEY=                         # outbound email
INBOUND_WEBHOOK_SECRET=dev-secret         # `openssl rand -hex 24` for real use

# ── Azure custom domains (production only) ────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=superprofile-rg
AZURE_APP_NAME=superprofile-api
# IDENTITY_ENDPOINT / IDENTITY_HEADER are injected by Azure Managed Identity —
# do not set them yourself.
